DJANGO_SETTINGS_MODULE=config.settings.local
ENVIRONMENT=local
APP_VERSION=0.1.0

# Local development defaults only. Do not use these values for production.
# For production/customer internet exposure:
# - set DJANGO_SETTINGS_MODULE=config.settings.production
# - keep DEBUG=False
# - replace SECRET_KEY with a private random value of at least 50 characters
# - set explicit ALLOWED_HOSTS, never *
# - use HTTPS values in CORS_ALLOWED_ORIGINS and CSRF_TRUSTED_ORIGINS
# - keep CORS_ALLOW_ALL_ORIGINS disabled
# - set private PostgreSQL/Redis credentials outside source control
# - run: python manage.py check --deploy --settings=config.settings.production
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3001,http://127.0.0.1:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
CORS_ALLOW_ALL_ORIGINS=False

DATABASE_URL=postgres://index:index@localhost:5432/index
DB_NAME=index
DB_USER=index
DB_PASSWORD=index
DB_HOST=localhost
DB_PORT=5432
POSTGRES_DB=index
POSTGRES_USER=index
POSTGRES_PASSWORD=index
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Production examples only; replace with customer-specific private values.
# DATABASE_URL=postgres://index_customer_user:private-password@db.internal:5432/index_customer
# REDIS_URL=redis://redis.internal:6379/0
# CORS_ALLOWED_ORIGINS=https://pos.customer.example
# CSRF_TRUSTED_ORIGINS=https://pos.customer.example

ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7
JWT_ALGORITHM=HS256
# JWT_SIGNING_KEY=use-a-separate-jwt-signing-key-if-needed
# JWT_AUDIENCE=index-api
# JWT_ISSUER=https://api.example.com
JWT_LEEWAY_SECONDS=0
JWT_UPDATE_LAST_LOGIN=True
PASSWORD_MIN_LENGTH=12
USER_THROTTLE_RATE=1000/hour
ANON_THROTTLE_RATE=100/hour

LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO
DJANGO_REQUEST_LOG_LEVEL=ERROR
LOG_FORMATTER=plain

SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
CSRF_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_REFERRER_POLICY=same-origin

BACKUP_STORAGE_PATH=/backups/index
BACKUP_RETENTION_DAYS=14

# Future notification integrations. Leave blank for local MVP.
TELEGRAM_BOT_TOKEN=
SMS_PROVIDER=
SMS_API_KEY=
