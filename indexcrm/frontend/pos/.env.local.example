# Local demo frontend settings.
# Copy to .env.local on the demo/customer machine.
# For a customer machine, point this at the reachable backend API.
# Local browser/monoblock example:
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Customer LAN example:
# NEXT_PUBLIC_API_BASE_URL=http://192.168.1.50:8000/api/v1
#
# Internet-facing deployments must use HTTPS and hardened backend settings.
# Do not expose the frontend publicly while the backend still uses local/demo
# SECRET_KEY, DEBUG, ALLOWED_HOSTS, CORS, CSRF, or HTTP-only settings.
